data = dielectron.drop(columns=["Run","Event", "M"])


from sklearn.preprocessing import StandardScaler
scaler = StandardScaler()
scaled = scaler.fit_transform(data)


scaled_df = pd.DataFrame(scaled, columns=data.columns)

scaled_df.describe().T


from sklearn.decomposition import PCA

pca = PCA()
X_pca = pca.fit_transform(scaled_df)





explained_variance = pca.explained_variance_ratio_

print(explained_variance)





cumulative_variance = np.cumsum(explained_variance)

print(cumulative_variance)


plt.figure(figsize=(8,5), dpi=150)

plt.plot(
    range(1, len(cumulative_variance)+1),
    cumulative_variance,
    marker='o'
)

plt.xlabel("Number of Principal Components")
plt.ylabel("Cumulative Explained Variance")
plt.title("Explained Variance by Principal Components")

plt.grid(True)

plt.show()


loadings = pd.DataFrame(
    pca.components_.T,
    columns=[f"PC{i+1}" for i in range(len(pca.components_))],
    index=data.columns
)

loadings


loadings[["PC1", "PC2"]]





loadings[['PC1', 'PC2']].sort_values(by='PC1', key=abs, ascending=False)


loadings[['PC1', 'PC2']].sort_values(by='PC2', key=abs, ascending=False)


pca2 = PCA(n_components=2)

X_pca = pca2.fit_transform(data)

pca_df = pd.DataFrame(
    X_pca,
    columns=["PC1","PC2"]
)


plt.figure(figsize=(8,6), dpi=150)

plt.scatter(
    pca_df["PC1"],
    pca_df["PC2"],
    s=4,
    alpha=0.3
)

plt.xlabel("PC1")
plt.ylabel("PC2")
plt.title("Electron Collision Events in PCA Space")

plt.show()


plt.figure(figsize=(8,6), dpi=150)

loadings["PC1"].sort_values().plot(kind="barh")

plt.title("Feature Contributions to PC1")
plt.xlabel("Loading")

plt.tight_layout()
plt.show()


plt.figure(figsize=(8,6), dpi=150)

loadings["PC2"].sort_values().plot(kind="barh")

plt.title("Feature Contributions to PC2")
plt.xlabel("Loading")

plt.tight_layout()
plt.show()


pca10 = PCA(n_components=10)

X10 = pca10.fit_transform(data)


from sklearn.cluster import KMeans

inertia = []

for k in range(2,11):

    model = KMeans(
        n_clusters=k,
        random_state=42
    )

    model.fit(X10)

    inertia.append(model.inertia_)


plt.figure(figsize=(8,5),dpi=150)

plt.plot(range(2,11),inertia,marker="o")

plt.xlabel("Number of Clusters")

plt.ylabel("Inertia")

plt.title("Elbow Method")

plt.grid(True)

plt.show()





kmeans = KMeans(
    n_clusters=6,
    random_state=42
)

labels = kmeans.fit_predict(X10)





pca_df["Cluster"] = labels

plt.figure(figsize=(8,6),dpi=150)

plt.scatter(
    pca_df["PC1"],
    pca_df["PC2"],
    c=pca_df["Cluster"],
    s=5,
    cmap="viridis"
)

plt.xlabel("PC1")
plt.ylabel("PC2")

plt.title("Clusters of Collision Events")

plt.colorbar(label="Cluster")

plt.show()





dielectron["Cluster"] = labels

dielectron.groupby("Cluster")["M"].describe()


for cluster in sorted(dielectron["Cluster"].unique()):
    plt.hist(
        dielectron.loc[
            dielectron["Cluster"]==cluster,
            "M"
        ],
        bins=60,
        alpha=0.5,
        label=f"Cluster {cluster}"
    )

plt.legend()

plt.xlabel("Invariant Mass")

plt.show()


cluster_summary = dielectron.groupby("Cluster")[[
    "E1","E2",
    "pt1","pt2",
    "eta1","eta2",
    "M"
]].mean()

cluster_summary


